# ── PostgreSQL (Database per Service) ────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=IamTenant_db;Username=postgres;Password=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
Redis__ConnectionString=localhost:6379

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RabbitMQ__Host=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest

# ── AWS Cognito ───────────────────────────────────────────────────────────────
Cognito__Region=ap-southeast-1
Cognito__UserPoolId=YOUR_USER_POOL_ID
Cognito__AppClientId=YOUR_APP_CLIENT_ID
Cognito__AppClientSecret=YOUR_APP_CLIENT_SECRET

# ── gRPC ──────────────────────────────────────────────────────────────────────
# Kestrel sẽ tự cấu hình qua appsettings.json — không cần thiết lập ở đây

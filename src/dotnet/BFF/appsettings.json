{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "Auth": {
    "CookieSecure": true,
    "CookieDomain": "",
    "Jwt": {
      "Authority": "",
      "Audience": ""
    }
  },

  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 50
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "GrpcServices": {
    "IamTenant": {
      "Url": "http://localhost:5001"
    },
    "RoutePlanning": {
      "Url": "http://localhost:5002"
    }
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "OpenTelemetry": {
    "ServiceName": "bff-gateway",
    "OtlpEndpoint": "http://localhost:4317"
  },

  "ReverseProxy": {
    "Routes": {
      "iam-route": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/iam" }
        ]
      },
      "route-planning-route": {
        "ClusterId": "route-planning-cluster",
        "Match": {
          "Path": "/api/route-planning/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/route-planning" }
        ]
      }
    },
    "Clusters": {
      "iam-cluster": {
        "Destinations": {
          "iam-primary": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "route-planning-cluster": {
        "Destinations": {
          "route-planning-primary": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}

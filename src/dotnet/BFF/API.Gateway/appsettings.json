{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "system-route": {
        "ClusterId": "system-cluster",
        "Match": {
          "Path": "/api/v1/system/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/v1/admin/{**catch-all}"
        }
      },
      "staff-route": {
        "ClusterId": "staff-cluster",
        "Match": {
          "Path": "/api/v1/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "system-cluster": {
        "Destinations": {
          "system-bff": {
            "Address": "https://localhost:7101"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "admin-bff": {
            "Address": "https://localhost:7102"
          }
        }
      },
      "staff-cluster": {
        "Destinations": {
          "staff-bff": {
            "Address": "https://localhost:7103"
          }
        }
      }
    }
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  },

  "Auth": {
    "CookieSecure": false,
    "CookieDomain": "",
    "Jwt": {
      "Authority": "https://cognito-idp.ap-southeast-1.amazonaws.com/YOUR_USER_POOL_ID",
      "Audience": "YOUR_APP_CLIENT_ID"
    }
  },

  "RateLimit": {
    "PermitLimit": 1000,
    "WindowSeconds": 60,
    "QueueLimit": 200
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },

  "GrpcServices": {
    "IamTenant": {
      "Url": "http://localhost:5001"
    },
    "RoutePlanning": {
      "Url": "http://localhost:5002"
    }
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "OpenTelemetry": {
    "ServiceName": "bff-gateway-dev",
    "OtlpEndpoint": "http://localhost:4317"
  },

  "ReverseProxy": {
    "Routes": {
      "iam-route": {
        "ClusterId": "iam-cluster",
        "Match": {
          "Path": "/api/iam/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/iam" }
        ]
      }
    },
    "Clusters": {
      "iam-cluster": {
        "Destinations": {
          "iam-primary": {
            "Address": "http://localhost:5001"
          }
        }
      }
    }
  }
}

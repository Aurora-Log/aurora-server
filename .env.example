# =============================================================================
# Aurora Server — Root Environment Variables Example
# =============================================================================
# Sao chép file này thành `.env` ở root và điền giá trị thực.
# KHÔNG commit file `.env` vào git (đã được thêm vào .gitignore).
# =============================================================================


# =============================================================================
# SECTION 1: INFRASTRUCTURE SHARED (dùng chung cho mọi service)
# =============================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Mỗi service có 1 database riêng (Database-per-Service pattern)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=changeme

# ── Redis / Valkey ─────────────────────────────────────────────────────────────
REDIS_CONNECTION_STRING=localhost:6379
# Nếu Redis có password: localhost:6379,password=secret

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/  # Mặc định là "/"


# =============================================================================
# SECTION 2: AWS
# =============================================================================

# ── AWS Credentials ────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
# Nếu chạy local (không có IAM Role): cần access key
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# ── AWS Cognito (IAM/Auth Service) ────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_APP_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Endpoint JWKS để BFF verify JWT (public key):
# https://cognito-idp.{region}.amazonaws.com/{userPoolId}/.well-known/jwks.json


# =============================================================================
# SECTION 3: IAM TENANT SERVICE (.NET gRPC)
# =============================================================================

IAMTENANT_DB=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=iam_tenant_db;Username=${POSTGRES_USERNAME};Password=${POSTGRES_PASSWORD}
IAMTENANT_GRPC_PORT=5001
# ConnectionStrings__DefaultConnection — được map vào appsettings
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=iam_tenant_db;Username=postgres;Password=changeme
Redis__ConnectionString=localhost:6379
RabbitMQ__Host=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest
Cognito__Region=ap-southeast-1
Cognito__UserPoolId=ap-southeast-1_XXXXXXXXX
Cognito__ClientId=XXXXXXXXXXXXXXXXXXXXXXXXXX
Cognito__ClientSecret=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# =============================================================================
# SECTION 4: BFF GATEWAY (.NET YARP)
# =============================================================================

BFF_HTTP_PORT=8080
BFF_HTTPS_PORT=8443

# ── JWT Validation (verify Cognito Access Token) ───────────────────────────────
BFF_JWT_AUTHORITY=https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXXX
BFF_JWT_AUDIENCE=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Downstream gRPC Service URLs (YARP sẽ forward tới đây) ────────────────────
BFF_IAMTENANT_GRPC_URL=http://localhost:5001
BFF_ROUTEPLANNING_GRPC_URL=http://localhost:5002

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Số request tối đa mỗi cửa sổ thời gian (per IP)
BFF_RATE_LIMIT_PERMIT_LIMIT=100
BFF_RATE_LIMIT_WINDOW_SECONDS=60
BFF_RATE_LIMIT_QUEUE_LIMIT=50

# ── Refresh Token (BFF gọi Cognito để auto-refresh) ────────────────────────────
BFF_COGNITO_TOKEN_ENDPOINT=https://aurora.auth.ap-southeast-1.amazoncognito.com/oauth2/token

# ── Health Dashboard ───────────────────────────────────────────────────────────
# Đặt thành true để enable /dashboard endpoint (chỉ dùng cho môi trường non-production)
BFF_ENABLE_DASHBOARD=true
BFF_DASHBOARD_PATH=/dashboard

# ── Redis cho Permission Cache ở BFF ──────────────────────────────────────────
BFF__Redis__ConnectionString=localhost:6379


# =============================================================================
# SECTION 5: ROUTE PLANNING AGENT SERVICE (.NET gRPC)
# =============================================================================

ROUTEPLANNING_DB=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=route_planning_db;Username=${POSTGRES_USERNAME};Password=${POSTGRES_PASSWORD}
ROUTEPLANNING_GRPC_PORT=5002


# =============================================================================
# SECTION 6: OBSERVABILITY
# =============================================================================

# ── OpenTelemetry / Tracing ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=aurora-server

# ── Serilog / Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=Information
# LOG_SEQ_URL=http://localhost:5341  # Optional: Seq log aggregation server


# =============================================================================
# SECTION 7: CORS / FRONTEND
# =============================================================================

# Allowed origins cho BFF CORS policy (dùng dấu phẩy để thêm nhiều origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://aurora.yourdomain.vn
